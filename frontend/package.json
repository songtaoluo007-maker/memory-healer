{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write src/**/*.{ts,vue,json,css}",
    "check": "prettier --check src/**/*.{ts,vue,json,css}"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.1",
    "vue-tsc": "^3.2.8",
    "web-vitals": "^5.3.0"
  }
}
